# Copy this file to ".env" and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API.
# These are the public "anon" values and are safe to ship in a client app —
# row-level security (see supabase/schema.sql) is what keeps data private.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key
